# Pune Vidyarthi Griha's College of Engineering & SS Dhamankar Institute of Management Chatbot Backend Environment Variables
# Copy this file to .env and update the values as needed

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model Configuration
MODEL_NAME=new_stem
EMBEDDING_SIZE=15

# Logging
LOG_LEVEL=INFO